  m_Script: {fileID: 0}
  m_Name: Dialogue1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Kaguya
    avatar: {fileID: 21300000, guid: ca85ad29208a0e346b547ca4d8a6e937, type: 3}
    content: Irohaaa... My stomach is rumbling. I'm so hungry.
  - speakerName: Kaguya
    avatar: {fileID: 21300000, guid: ca85ad29208a0e346b547ca4d8a6e937, type: 3}
    content: I'm craving your special, fluffy pancakes!
  - speakerName: Iroha
    avatar: {fileID: 21300000, guid: 681f82db4902e9a4fa3fe39f7f30c840, type: 3}
    content: My pancakes? But you know my cooking is a bit... hit-or-miss.
  - speakerName: Kaguya
    avatar: {fileID: 21300000, guid: ca85ad29208a0e346b547ca4d8a6e937, type: 3}
    content: I don't mind! They're the best because you make them for me.
  - speakerName: Iroha
    avatar: {fileID: 21300000, guid: 681f82db4902e9a4fa3fe39f7f30c840, type: 3}
    content: (Sighs softly) You always know just what to say, don't you?
  - speakerName: Iroha
    avatar: {fileID: 21300000, guid: 681f82db4902e9a4fa3fe39f7f30c840, type: 3}
    content: Alright, I'll get the ingredients. One batch of pancakes, coming right
      up!
